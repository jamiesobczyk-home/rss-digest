<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Digest Archive</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>
  <header class="site-header">
    <div class="header-inner">
      <span class="site-label">Daily Digest</span>
      <h1 class="header-date">Archive</h1>
      <div class="header-meta">{{ entries|length }} digest{{ 's' if entries|length != 1 else '' }}</div>
    </div>
  </header>

  <main class="content">
    {% if entries %}
    <table class="archive-table">
      <thead>
        <tr>
          <th>Date</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {% for entry in entries %}
        <tr>
          <td class="archive-date">{{ entry.label }}</td>
          <td class="archive-link"><a href="{{ entry.file }}">Read &rarr;</a></td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% else %}
    <p class="empty-state">No digests yet. Run <code>python digest.py</code> to generate your first one.</p>
    {% endif %}
  </main>

  <footer class="site-footer">
    Generated by rss-digest
  </footer>
</body>
</html>
